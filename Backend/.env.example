# Supabase -> Project Settings -> Database -> Connection string (URI).
# Use the connection-pooler URI (port 6543) for serverless/pooled access,
# or the direct connection (port 5432). Password is your DB password.
# Dialect is +psycopg (psycopg 3) to match requirements.txt.
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# CORS origin for the React dev server.
FRONTEND_ORIGIN=http://localhost:5173

# OpenAI key for the /insights and /chat AI features (optional —
# the app boots without it, those endpoints return 503).
OPENAI_API_KEY=sk-...