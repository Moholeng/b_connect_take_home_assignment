# Supabase -> Project Settings -> Database -> Connection string (URI).
# Use the connection-pooler URI (port 6543) for serverless/pooled access,
# or the direct connection (port 5432). Password is your DB password.
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# CORS origin for the React dev server.
FRONTEND_ORIGIN=http://localhost:5173